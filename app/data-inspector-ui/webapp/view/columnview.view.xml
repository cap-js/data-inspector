<mvc:View
    controllerName="sap.cap.datainspector.datainspectorui.controller.columnview"
	xmlns="sap.f"
	xmlns:m="sap.m"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:menu="sap.m.table.columnmenu"
	xmlns:app="http://schemas.sap.com/sapui5/extension/sap.ui.core.CustomData/1">
	<DynamicPage class="sapUiNoContentPadding">
		<title>
			<DynamicPageTitle>
				<navigationActions>
					<m:Button type="Transparent" icon="sap-icon://full-screen" press=".handleFullScreen" tooltip="{i18n>enterFullScreenMode}" visible="{= ${/actionButtonsInfo/midColumn/fullScreen} !== null }"/>
					<m:Button type="Transparent" icon="sap-icon://exit-full-screen" press=".handleExitFullScreen" tooltip="{i18n>exitFullScreenMode}" visible="{= ${/actionButtonsInfo/midColumn/exitFullScreen} !== null }"/>
					<m:Button type="Transparent" icon="sap-icon://decline" press=".handleClose" tooltip="{i18n>closeColumn}" visible="{= ${/actionButtonsInfo/midColumn/closeColumn} !== null }"/>
				</navigationActions>
				<heading>
					<m:Title text="{view>/name}" level="H1"/>
					
				</heading>
			</DynamicPageTitle>
		</title>

		<dependents>
			<menu:Menu id="menu" beforeOpen="onBeforeOpenColumnMenu">
                    <menu:QuickSort change="onSort">
                        <menu:items>
                            <menu:QuickSortItem></menu:QuickSortItem>
                        </menu:items>
                    </menu:QuickSort>
                </menu:Menu>
		</dependents>
		
		<content>
			<m:VBox height="100%" class="sapUiNoContentPadding">
				<m:MessageStrip
        			text="{i18n>alertToSelectColumns}"
        			type="Information"
					showIcon="true"
		    		showCloseButton="true"
    				class="sapUiSmallMarginBottom"/>
				<m:OverflowToolbar class="sapFDynamicPageAlignContent">
					<m:Title text="{i18n>elements} ({= ${EntityColumnList>/elements}.length })"/>
					<m:ToolbarSpacer/>
					<m:SearchField search=".onSearch" width="17.5rem"/>
					<m:Button text="{i18n>showData}"
                        type="Transparent"
						enabled="{view>/showDataEnabled}"
                        press=".onShowDataPress"/>
					<m:ToolbarSeparator />
				</m:OverflowToolbar>
				<m:ScrollContainer 
					height="calc(100vh - 170px)"
					width="100%"
					vertical="true"
					horizontal="true">
					<m:Table
						id="columnTable"
						inset="false"
						mode="MultiSelect"
						selectionChange="onColumnTableSelectionChange"
						items="{
							path: 'EntityColumnList>/elements'	
						}"
						class="sapFDynamicPageAlignContent"
						width="auto"
						fixedLayout="false">
						<m:columns>
							<m:Column headerMenu="menu" app:p13nKey="name" width="10rem">
								<m:Text text="{i18n>elementName}" wrapping="false"/>
							</m:Column>
							<m:Column headerMenu="menu" app:p13nKey="type" width="8rem">
								<m:Text text="{i18n>type}" wrapping="false"/>
							</m:Column>
							<m:Column headerMenu="menu" app:p13nKey="isKey" width="7rem">
								<m:Text text="{i18n>isKey}" wrapping="false"/>
							</m:Column>
							<m:Column headerMenu="menu" app:p13nKey="defaultValue" width="12rem">
								<m:Text text="{i18n>defaultValue}" wrapping="false"/>
							</m:Column>
							<m:Column headerMenu="menu" app:p13nKey="isSensitive" width="11rem">
								<m:Text text="{i18n>isSensitive}" wrapping="false"/>
							</m:Column>
							<m:Column headerMenu="menu" app:p13nKey="isNotNull" width="9rem">
								<m:Text text="{i18n>isNotNull}" wrapping="false"/>
							</m:Column>
							<m:Column headerMenu="menu" app:p13nKey="isVirtual" width="9rem">
								<m:Text text="{i18n>isVirtual}" wrapping="false"/>
							</m:Column>
						</m:columns>
						<m:items>
							<m:ColumnListItem >
								<m:cells>
									<m:Text text="{EntityColumnList>name}" wrapping="false"/>
									<m:Text text="{= ${EntityColumnList>length} ? ${EntityColumnList>type} + '(' + ${EntityColumnList>length} + ')' : ${EntityColumnList>type} }" wrapping="false"/>
									<m:Text text="{EntityColumnList>isKey}" wrapping="false"/>
									<m:Text text="{EntityColumnList>defaultValue}" wrapping="false"/>
									<m:Text text="{EntityColumnList>isSensitive}" wrapping="false"/>
									<m:Text text="{EntityColumnList>isNotNull}" wrapping="false"/>
									<m:Text text="{EntityColumnList>isVirtual}" wrapping="false"/>		
								</m:cells>
							</m:ColumnListItem>
						</m:items>
					</m:Table>
				</m:ScrollContainer>
			</m:VBox>
		</content>
	</DynamicPage>
</mvc:View>