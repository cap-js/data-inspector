<Dialog
    title="{i18n>advanceFilter}"
    id="advancedFilterDialog"
	contentWidth="600px"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <OverflowToolbar class="sapFDynamicPageAlignContent">
		<Title text="{i18n>filters}({view>/filterRowCount})"/>
		<ToolbarSpacer/>
		<Button text="{i18n>add}"
            type="Transparent"
            press=".onAddPress"/>
		<ToolbarSeparator />
	</OverflowToolbar>
	<Table
		id="AdvancedFilterTable"
		inset="false"
        class="sapFDynamicPageAlignContent"
		width="auto">
		<columns>
			<Column>
				<Text text="{i18n>field}"/>
	        </Column>
			<Column>
				<Text text="{i18n>value}"/>
			</Column>
			<Column>
			</Column>
		</columns>
		<items>
			<ColumnListItem >
				<cells>
					<Select id="columnSelect" items="{
                        path: 'view>/selectedColumns'
                    }">
                    <items>
                        <core:Item key="{view>}" text="{view>}" />
                    </items>
                    </Select>
					<MultiInput 
                        id="multiInput" 
                        placeholder="{i18n>enterFilterValues}" 
                        valueHelpRequest="onValueHelpRequest"/>
					<Button
						id="removeFilterBtn"
						type="Transparent"
						icon="sap-icon://decline"
						press=".onRemovePress"
						tooltip="{i18n>removeFilter}"/>
				</cells>
			</ColumnListItem>
		</items>
	</Table>
    <beginButton>
        <Button text="{i18n>apply}" press=".onApplyAdvancedFilter"/>
    </beginButton>
    <endButton>
        <Button text="{i18n>cancel}" press=".onCancelAdvancedFilter"/>
    </endButton>
</Dialog>