{
  "name": "data-inspector-ui",
  "version": "0.0.1",
  "description": "An SAP Fiori application.",
  "keywords": [
    "ui5",
    "openui5",
    "sapui5"
  ],
  "main": "webapp/index.html",
  "devDependencies": {
    "@ui5/cli": "^4.0.26",
    "rimraf": "^6.0.1",
    "ui5-task-zipper": "^3.4.4"
  },
  "ui5": {
    "dependencies": [
      "ui5-task-zipper"
    ]
  },
  "scripts": {
    "deploy-config": "npx -p @sap/ux-ui5-tooling fiori add deploy-config cf",
    "build": "rimraf dist && ui5 build --include-task=generateCachebusterInfo",
    "postbuild": "cpx xs-app.json dist/",
    "build:cf": "rimraf dist && ui5 build preload --clean-dest --config ui5-deploy.yaml --include-task=generateCachebusterInfo"
  }
}
