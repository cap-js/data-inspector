meta {
  name: GET EntityDefinitions $filter contains type
  type: http
  seq: 22
}

get {
  url: http://localhost:4004/odata/v4/data-inspector/EntityDefinition?$filter=contains(type, 'table')&$select=title,name&$count=true
  body: none
  auth: basic
}

params:query {
  $filter: contains(type, 'table')
  $select: title,name
  $count: true
}

auth:basic {
  username: alice
}
