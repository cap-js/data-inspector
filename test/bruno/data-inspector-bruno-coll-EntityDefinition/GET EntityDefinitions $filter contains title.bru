meta {
  name: GET EntityDefinitions $filter contains title
  type: http
  seq: 21
}

get {
  url: http://localhost:4004/odata/v4/data-inspector/EntityDefinition?$filter=contains(title, 'Pro')&$select=title,name&$count=true
  body: none
  auth: basic
}

params:query {
  $filter: contains(title, 'Pro')
  $select: title,name
  $count: true
}

auth:basic {
  username: alice
}
