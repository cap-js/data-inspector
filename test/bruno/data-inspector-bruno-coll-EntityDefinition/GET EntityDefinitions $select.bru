meta {
  name: GET EntityDefinitions $select
  type: http
  seq: 29
}

get {
  url: http://localhost:4004/odata/v4/data-inspector/EntityDefinition?$select=name, type, dataSource&$filter=dataSource eq 'service'&$count=true
  body: none
  auth: basic
}

params:query {
  $select: name, type, dataSource
  $filter: dataSource eq 'service'
  $count: true
}

auth:basic {
  username: alice
}
