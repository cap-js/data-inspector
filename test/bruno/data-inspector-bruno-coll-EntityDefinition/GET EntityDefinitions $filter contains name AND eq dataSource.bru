meta {
  name: GET EntityDefinitions $filter contains name AND eq dataSource
  type: http
  seq: 17
}

get {
  url: http://localhost:4004/odata/v4/data-inspector/EntityDefinition?$filter=contains(name, 'Product') and dataSource eq 'service'&$select=name&$count=true
  body: none
  auth: basic
}

params:query {
  $filter: contains(name, 'Product') and dataSource eq 'service'
  $select: name
  $count: true
}

auth:basic {
  username: alice
}
