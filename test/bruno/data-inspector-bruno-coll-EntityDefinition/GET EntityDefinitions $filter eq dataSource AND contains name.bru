meta {
  name: GET EntityDefinitions $filter eq dataSource AND contains name
  type: http
  seq: 16
}

get {
  url: http://localhost:4004/odata/v4/data-inspector/EntityDefinition?$filter=dataSource eq 'service' and contains(name, 'Product')&$select=name&$count=true
  body: none
  auth: basic
}

params:query {
  $filter: dataSource eq 'service' and contains(name, 'Product')
  $select: name
  $count: true
}

auth:basic {
  username: alice
}
