meta {
  name: GET Data db r_filter
  type: http
  seq: 20
}

get {
  url: http://localhost:4004/odata/v4/data-inspector/Data?$filter=entityName eq 'datainspector.test.db.Product'&r_select=description,productName&r_filter=productName eq 'IPod' or contains(productName, 'Apple')
  body: none
  auth: basic
}

params:query {
  $filter: entityName eq 'datainspector.test.db.Product'
  r_select: description,productName
  r_filter: productName eq 'IPod' or contains(productName, 'Apple')
}

auth:basic {
  username: alice
}
